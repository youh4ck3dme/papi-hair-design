# ==============================================================
# PAPI HAIR DESIGN – Booking System
# Premenné prostredia (skopíruj do .env a vyplň hodnoty)
# ==============================================================

# --- Salon Quick-Switch login page ---
# Tieto emaily musia byť zhodné s Firebase Auth používateľmi
VITE_PAPI_EMAIL=papi@papihairdesign.sk
VITE_MISKA_EMAIL=miska@papihairdesign.sk
VITE_MATO_EMAIL=mato@papihairdesign.sk

# --- Vercel produkčné nasadenie ---
# Nastaviť v Vercel Dashboard → Project → Settings → Environment Variables
VITE_VERCEL=true

# --- Sentry configuration ---
VITE_SENTRY_DSN=your-sentry-dsn
VITE_SENTRY_ENABLE_DEV=false
SENTRY_AUTH_TOKEN=your-auth-token

# --- reCAPTCHA v3 (verejná rezervácia) – voliteľné ---
# VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# ==============================================================
# POZNÁMKY:
# - Nikdy nepridávaj Firebase service account kľúče do .env alebo klientského kódu!
# - Súbor .env.example je bezpečné commitnúť (obsahuje len verejné kľúče).
# - Súbor .env NIKDY necommituj (je v .gitignore).
# - Dev server beží na http://localhost:5678/papihairsalon2026
# ==============================================================

# --- Firebase (projekt: RezerváciaPHD2026) ---
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id
VITE_FIREBASE_FUNCTIONS_URL=https://europe-west1-your-project-id.cloudfunctions.net
