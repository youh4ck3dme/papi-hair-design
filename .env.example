# ==============================================================
# PAPI HAIR DESIGN – Booking System
# Premenné prostredia (skopíruj do .env a vyplň hodnoty)
# ==============================================================

# --- Salon Quick-Switch login page ---
# Tieto emaily musia byť zhodné s Firebase Auth používateľmi
VITE_PRIMARY_OWNER_EMAIL=papi@papihairdesign.sk
VITE_EMPLOYEE_EMAILS=mato@papihairdesign.sk,miska@papihairdesign.sk
# Backend / Functions aliasy pre bootstrap a role enforcement.
PRIMARY_BUSINESS_ID=papi-hair-design-main
PRIMARY_OWNER_EMAIL=papi@papihairdesign.sk
BOOTSTRAP_EMPLOYEE_EMAILS=mato@papihairdesign.sk,miska@papihairdesign.sk
# Legacy aliases ponechané kvôli spätnej kompatibilite so starším bootstrap flowom.
VITE_PAPI_EMAIL=papi@papihairdesign.sk
VITE_MISKA_EMAIL=miska@papihairdesign.sk
VITE_MATO_EMAIL=mato@papihairdesign.sk
# Primárny tenant/business fallback pre bootstrap a booking shell.
VITE_PRIMARY_BUSINESS_ID=papi-hair-design-main
# Voliteľné: dodatočný admin allowlist (CSV) pre bootstrap/autoredirect po login-e.
# Príklad: VITE_ADMIN_ALLOWLIST=owner@papihairdesign.sk,manager@papihairdesign.sk
# Ak nie je nastavené, použijú sa vyššie profilové emaily.
# VITE_ADMIN_ALLOWLIST=
# V produkcii nechaj false (route /papihairsalon2026 bude vypnutá)
VITE_ENABLE_SALON_LOGIN=false
# Voliteľná extra vstupná brána pred výberom profilu.
# Ak nie je nastavená, gate sa úplne vypne (žiadny default fallback).
# VITE_SALON_GATE_PASSWORD=your-strong-random-passphrase
# V produkcii nechaj false (route /bootstrap bude vypnutá)
VITE_ENABLE_BOOTSTRAP=false
# V produkcii nechaj false (buyer-facing platform page ostáva vypnutá, kým nebude pripravená)
VITE_ENABLE_PLATFORM_PAGE=false

# --- reCAPTCHA v3 (verejná rezervácia) – voliteľné ---

# ==============================================================
# POZNÁMKY:
# - Nikdy nepridávaj Firebase service account kľúče do .env alebo klientského kódu!
# - Súbor .env.example je bezpečné commitnúť (obsahuje len verejné kľúče).
# - Súbor .env NIKDY necommituj (je v .gitignore).
# - Dev server beží na http://localhost:5678/papihairsalon2026 (v DEV režime)
# ==============================================================

# --- Firebase (projekt: RezerváciaPHD2026) ---
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id
# Región pre httpsCallable/getFunctions (aktuálne nasadené funkcie sú v europe-west1)
VITE_FIREBASE_FUNCTIONS_REGION=europe-west1

# --- App Check (Security) ---
# Debug token pre localhost vývoj (získate vo Firebase Console -> App Check -> Apps -> Manage debug tokens)
VITE_FIREBASE_APP_CHECK_DEBUG_TOKEN=your-app-check-debug-token
# Preferované pre App Check (ReCaptcha Enterprise)
VITE_FIREBASE_APP_CHECK_SITE_KEY=your-app-check-site-key

# --- SMS brána (Twilio) – nastav cez Firebase Functions secrets / Secret Manager ---
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+421900000000
# ADMIN_NOTIFICATION_EMAIL=admin@fyzioafit.sk

# --- Python / Streamlit AI toolkit (local) ---
# Spúšťanie: streamlit run app.py
STREAMLIT_SERVER_PORT=8501
GROQ_API_KEY=your-groq-api-key
HUGGINGFACE_TOKEN=your-huggingface-token
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_TOKEN_SECRET=your-x-access-token-secret

# --- Billing checkout (Firebase Functions) ---
# Zapni len keď je backend billing plne nakonfigurovaný.
BILLING_ENABLED=false
# CSV zoznam Stripe price IDs povolených pre checkout callable.
# STRIPE_ALLOWED_PRICE_IDS=price_1Ov_pro_monthly,price_1Ov_ent_monthly
# URL na backend endpoint, ktorý vytvorí Stripe checkout session.
# STRIPE_CHECKOUT_URL_BASE=https://example.com/api/billing/checkout
