AUTH_TYPE=UsernamePassword
DATABASE=(default)
DATABASE_REGION=eur3
DEFAULT_FROM=booking@papihairdesign.sk
DEFAULT_REPLY_TO=booking@papihairdesign.sk
firebaseextensions.v1beta.function/location=us-central1
firebaseextensions.v1beta.function/minInstances=0
firebaseextensions.v1beta.function/vpcConnectorEgressSettings=VPC_CONNECTOR_EGRESS_SETTINGS_UNSPECIFIED
firebaseextensions.v1beta.v2function/memory=256Mi
MAIL_COLLECTION=mail
OAUTH_PORT=465
OAUTH_SECURE=true
SMTP_CONNECTION_URI=smtps://booking@papihairdesign.sk@smtp.m1.websupport.sk:465
SMTP_PASSWORD=projects/${param:PROJECT_NUMBER}/secrets/FIRESTORE_SEND_EMAIL_SMTP_PASSWORD_1ZMR/versions/latest
TTL_EXPIRE_TYPE=never
TTL_EXPIRE_VALUE=1
